# ============================================================================
# Portfolio — .gitignore
# Reglas globales para Java/Maven, Node/Next.js, Docker, IDEs
# ============================================================================

# Entorno — NUNCA al repositorio
.env
*.env.local
!.env.example

# Java / Maven / Gradle
target/
build/
*.class
*.jar
*.war
.gradle/
# NOTA: maven-wrapper.jar SÍ debe commitearse (es parte del wrapper, lo usa mvnw)

# Spring Boot
spring-boot-*.log
logs/
HELP.md

# Node / Next.js
node_modules/
.next/
.cache/
dist/
*.tsbuildinfo

# Docker
.docker/

# IDE — VS Code
.vscode/settings.json
.vscode/launch.json
# extensions.json SÍ se commitea (recomendaciones compartidas)

# IDE — IntelliJ
.idea/
*.iml

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# Infraestructura — datos locales y secretos
infrastructure/traefik/certs/*.pem
infrastructure/traefik/certs/*.crt
infrastructure/traefik/certs/*.key
infrastructure/traefik/acme.json

# Test coverage
coverage/
*.lcov
jacoco.exec
jacoco/

# Archivos temporales / backups
tmp/
*.bak
*.tmp

# Python (por si acaso)
*.pyc
__pycache__/

# Logs generales (runtime)
*.log
!docs/**/*.log
# Scratch personal — no subir al repo
comandos.txt
