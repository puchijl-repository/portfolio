# =============================================================================
# PORTFOLIO — Variables de entorno
# Copia este archivo a .env y ajusta los valores
# NUNCA subas .env a GitHub — está en .gitignore
# =============================================================================

# PostgreSQL
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio_secret_change_in_prod

# Redis
REDIS_PASSWORD=redis_secret_change_in_prod

# RabbitMQ
RABBITMQ_USER=portfolio
RABBITMQ_PASSWORD=rabbitmq_secret_change_in_prod

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin_change_in_prod

# n8n
N8N_USER=admin
N8N_PASSWORD=n8n_secret_change_in_prod

# pgAdmin (profile: tools)
PGADMIN_EMAIL=admin@portfolio.local
PGADMIN_PASSWORD=admin
